# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# IntaSend Payment
INTASEND_PUBLIC_API_KEY=your_intasend_public_key
NEXT_PUBLIC_INTASEND_PUBLIC_KEY=your_intasend_public_key
INTASEND_SECRET_KEY=your_intasend_secret_key
INTASEND_WEBHOOK_SECRET=your_webhook_challenge_secret

# IntaSend Plan IDs (use period-specific IDs if monthly/yearly have different IntaSend plans)
INTASEND_PLAN_SUPPORTER_MONTHLY=your_supporter_monthly_plan_id
INTASEND_PLAN_SUPPORTER_YEARLY=your_supporter_yearly_plan_id
INTASEND_PLAN_FORGOTTEN_MONTHLY=your_forgotten_monthly_plan_id
INTASEND_PLAN_FORGOTTEN_YEARLY=your_forgotten_yearly_plan_id
INTASEND_PLAN_WATCHER_MONTHLY=your_watcher_monthly_plan_id
INTASEND_PLAN_WATCHER_YEARLY=your_watcher_yearly_plan_id

# Backward-compatible fallback plan IDs
INTASEND_PLAN_SUPPORTER=your_supporter_plan_id
INTASEND_PLAN_FORGOTTEN=your_forgotten_plan_id
INTASEND_PLAN_WATCHER=your_watcher_plan_id

# Site URL
NEXT_PUBLIC_SITE_URL=https://streetlightstory.site
